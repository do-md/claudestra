# Claudestra Web — 环境变量模板。复制为 .env.local 并填值。

# 外部脚本/skill 调用受保护 API 时的 Bearer/x-api-key（用 crypto.randomBytes 生成）
INTERNAL_API_KEY=

# Bridge 网关地址（Next.js 服务端 localhost 调用，永不暴露给浏览器）
BRIDGE_HTTP_URL=http://127.0.0.1:3847

# Bridge /api/v1 的 Bearer token（bun src/manager.ts token-add web-ui --agents '''*,master''' --force 签发）
CLAUDESTRA_API_TOKEN=

# Web Push 零配置——原生 VAPID,密钥首次使用时自动生成并持久化到
# ~/.claude-orchestrator/web/push-vapid.json,无需任何第三方账号。
# (v2.10 前曾计划 OneSignal,已改为自托管方案)

# 数据根目录覆盖（默认 ~/.claude-orchestrator/web）
# CLAUDESTRA_DATA_ROOT=
